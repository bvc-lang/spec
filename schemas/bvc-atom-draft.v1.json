{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bvc-lang.dev/schemas/bvc-atom-draft.v1.json",
  "title": "BVC Atom Draft V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile", "name", "basis", "vector", "goal"],
  "properties": {
    "profile": {
      "type": "string",
      "enum": ["charter", "charter_section", "work_item", "plan", "prompt_rule", "compiler", "trace"]
    },
    "name": {
      "type": "string",
      "pattern": "^[A-Za-zА-Яа-яЁё0-9_]+$"
    },
    "basis": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "vector": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "goal": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "propertyNames": {
        "pattern": "^[A-Za-zА-Яа-яЁё0-9_.-]+$"
      }
    },
    "lang": {
      "type": "string",
      "enum": ["en", "ru"],
      "default": "en",
      "description": "BVC dialect for atom keys (Detect-or-Declare)."
    },
    "checks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "structuredEvidence": {
      "type": "array",
      "description": "Optional machine-readable evidence records (dual view with prose evidence strings).",
      "items": { "$ref": "#/$defs/evidenceRecordV1" }
    }
  },
  "$defs": {
    "evidenceRecordV1": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "status"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["command", "test", "file", "change", "decision", "worker-run", "manual-review", "blocker"]
        },
        "status": {
          "type": "string",
          "enum": ["succeeded", "failed", "pending", "skipped", "blocked"]
        },
        "taskId": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "command": { "type": "string", "minLength": 1 },
        "cmd": { "type": "string", "minLength": 1 },
        "exitCode": { "type": "integer" },
        "exit_code": { "type": "integer" },
        "source": { "type": "string" },
        "time": { "type": "string" }
      }
    }
  }
}
